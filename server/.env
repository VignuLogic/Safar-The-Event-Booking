# ============================================================
# .env — Environment Variables
# ============================================================
# This file stores SECRET config values.
# NEVER push this to GitHub! Add .env to .gitignore
#
# dotenv package reads this file and puts values into process.env
# Access in code: process.env.MONGO_URI
# ============================================================

# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/safar
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/safar
MONGO_URI=mongodb://localhost:27017/safar

# Port for the Express server
PORT=5000

# JWT Secret — used to sign login tokens (any random string)
JWT_SECRET=safar_secret_key_2025